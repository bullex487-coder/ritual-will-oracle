# .env.local.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── AI (Required) ─────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Ritual Blockchain (Required after contract deployment) ────────────────────
# Deploy OracleVault.sol on Remix IDE to Ritual Testnet (Chain ID: 1979)
# Then paste the deployed contract address below:
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# ── Ritual RPC (Optional — defaults to the public endpoint) ──────────────────
NEXT_PUBLIC_RITUAL_RPC=https://rpc.ritualfoundation.org
